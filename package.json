{
  "name": "rift-heroes",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && npm run server:check && npm run server:bundle && vite build",
    "lint": "oxlint",
    "test:server": "tsx --test server/**/*.test.ts src/api/**/*.test.ts src/game/**/*.test.ts",
    "preview": "vite preview",
    "prod:compose:check": "node scripts/assert-production-compose.mjs",
    "server:check": "tsc -p tsconfig.server.json",
    "server:bundle": "esbuild server/index.ts --bundle --platform=node --format=esm --target=node24 --outfile=dist-server/index.mjs",
    "server:dev": "tsx server/index.ts"
  },
  "dependencies": {
    "canvas-confetti": "^1.9.4",
    "decimal.js-light": "^2.5.1",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.23.0",
    "pixi.js": "^8.19.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "esbuild": "^0.28.1",
    "oxlint": "^1.71.0",
    "tsx": "^4.23.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
